# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
DALLE_MODEL=gpt-image-2-2026-04-21

# Pinecone
PINECONE_API_KEY=...
PINECONE_INDEX_NAME=bible-kjv
PINECONE_ENVIRONMENT=us-east-1-aws

# Redis
REDIS_URL=redis://redis:6379

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://user:pass@postgres:5432/christianai

# App
ENVIRONMENT=development
SECRET_KEY=change-me
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001
LOG_LEVEL=INFO
LOCAL_FALLBACKS=true
EXTERNAL_REQUEST_TIMEOUT_SECONDS=60
IMAGE_GENERATION_TIMEOUT_SECONDS=300
OPENAI_MAX_RETRIES=2
AUTO_CREATE_TABLES=true
API_KEYS=
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=120
MAX_REQUEST_BODY_BYTES=1000000
METRICS_ENABLED=true

# Next.js
